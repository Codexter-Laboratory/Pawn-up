generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PuzzleRushSnapshot {
  id           Int      @id @default(autoincrement())
  username     String
  asOf         DateTime

  attemptsTotal Int?
  scoreTotal    Int?

  fetchedAt    DateTime @default(now())

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([username, asOf])
  @@index([username, asOf])
}

model DailyPuzzleCheckin {
  id       Int      @id @default(autoincrement())
  username String
  asOf     DateTime
  solved   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([username, asOf])
  @@index([username, asOf])
}

